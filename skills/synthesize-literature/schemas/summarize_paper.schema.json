{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "summarize_paper",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "research_objective",
    "key_contribution",
    "research_type",
    "study_design",
    "population_or_corpus",
    "analytical_approach",
    "main_results",
    "interpretative_claims",
    "methodological_strengths",
    "methodological_limitations",
    "bias_risk",
    "theoretical_framework",
    "relevance_score",
    "relevance_justification"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1200
    },
    "research_objective": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 5,
          "maxLength": 400
        }
      ]
    },
    "key_contribution": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "research_type": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "enum": [
            "empirique",
            "théorique",
            "revue",
            "méta-analyse",
            "autre"
          ]
        }
      ]
    },
    "study_design": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 5,
          "maxLength": 400
        }
      ]
    },
    "population_or_corpus": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 5,
          "maxLength": 500
        }
      ]
    },
    "analytical_approach": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 5,
          "maxLength": 400
        }
      ]
    },
    "main_results": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 5,
        "maxLength": 350
      }
    },
    "interpretative_claims": {
      "type": "array",
      "minItems": 0,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 5,
        "maxLength": 350
      }
    },
    "methodological_strengths": {
      "type": "array",
      "minItems": 0,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 5,
        "maxLength": 250
      }
    },
    "methodological_limitations": {
      "type": "array",
      "minItems": 0,
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 5,
        "maxLength": 250
      }
    },
    "bias_risk": {
      "type": "string",
      "enum": [
        "faible",
        "modéré",
        "élevé",
        "non évaluable"
      ]
    },
    "theoretical_framework": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 3,
          "maxLength": 300
        }
      ]
    },
    "relevance_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "relevance_justification": {
      "type": "string",
      "minLength": 20,
      "maxLength": 900
    }
  }
}
