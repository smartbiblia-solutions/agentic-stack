{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "synthesize_papers_thematic",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "themes",
    "cross_cutting_findings",
    "dominant_theoretical_frameworks",
    "methodological_trends",
    "research_gaps",
    "future_directions",
    "epistemic_limitations",
    "narrative_synthesis"
  ],
  "properties": {
    "themes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "definition",
          "theme_type",
          "papers",
          "core_findings",
          "consensus",
          "tensions",
          "methodological_pattern",
          "strength_of_evidence"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 120
          },
          "definition": {
            "type": "string",
            "minLength": 10,
            "maxLength": 600
          },
          "theme_type": {
            "type": "string",
            "enum": [
              "descriptive",
              "explanatory",
              "normative"
            ]
          },
          "papers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          },
          "core_findings": {
            "type": "string",
            "minLength": 20,
            "maxLength": 1200
          },
          "consensus": {
            "type": "string",
            "minLength": 10,
            "maxLength": 900
          },
          "tensions": {
            "type": "string",
            "minLength": 10,
            "maxLength": 900
          },
          "methodological_pattern": {
            "type": "string",
            "minLength": 10,
            "maxLength": 700
          },
          "strength_of_evidence": {
            "type": "string",
            "enum": [
              "faible",
              "modéré",
              "fort"
            ]
          }
        }
      }
    },
    "cross_cutting_findings": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1600
    },
    "dominant_theoretical_frameworks": {
      "type": "array",
      "minItems": 0,
      "maxItems": 12,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 150
      }
    },
    "methodological_trends": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1600
    },
    "research_gaps": {
      "type": "array",
      "minItems": 0,
      "maxItems": 15,
      "items": {
        "type": "string",
        "minLength": 5,
        "maxLength": 250
      }
    },
    "future_directions": {
      "type": "array",
      "minItems": 0,
      "maxItems": 15,
      "items": {
        "type": "string",
        "minLength": 5,
        "maxLength": 250
      }
    },
    "epistemic_limitations": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1600
    },
    "narrative_synthesis": {
      "type": "string",
      "minLength": 200,
      "maxLength": 9000
    }
  }
}
