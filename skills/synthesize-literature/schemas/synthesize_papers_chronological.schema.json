{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "synthesize_papers_chronological",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "periods",
    "turning_points",
    "evolution_patterns",
    "underexplored_periods",
    "research_gaps",
    "future_directions",
    "epistemic_observations",
    "narrative_synthesis"
  ],
  "properties": {
    "periods": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "period",
          "definition",
          "papers",
          "dominant_questions",
          "key_developments",
          "dominant_approaches",
          "theoretical_orientation",
          "evidence_strength"
        ],
        "properties": {
          "period": {
            "type": "string",
            "minLength": 4,
            "maxLength": 20
          },
          "definition": {
            "type": "string",
            "minLength": 10,
            "maxLength": 600
          },
          "papers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          },
          "dominant_questions": {
            "type": "string",
            "minLength": 10,
            "maxLength": 800
          },
          "key_developments": {
            "type": "string",
            "minLength": 10,
            "maxLength": 1000
          },
          "dominant_approaches": {
            "type": "string",
            "minLength": 10,
            "maxLength": 800
          },
          "theoretical_orientation": {
            "type": "string",
            "minLength": 2,
            "maxLength": 500
          },
          "evidence_strength": {
            "type": "string",
            "enum": [
              "faible",
              "modéré",
              "fort"
            ]
          }
        }
      }
    },
    "turning_points": {
      "type": "array",
      "minItems": 0,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "period_or_year",
          "type",
          "description",
          "impact"
        ],
        "properties": {
          "period_or_year": {
            "type": "string",
            "minLength": 2,
            "maxLength": 20
          },
          "type": {
            "type": "string",
            "enum": [
              "conceptual",
              "methodological",
              "technological",
              "empirical"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 800
          },
          "impact": {
            "type": "string",
            "minLength": 10,
            "maxLength": 800
          }
        }
      }
    },
    "evolution_patterns": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conceptual_trends",
        "methodological_trends",
        "theoretical_shifts",
        "evidence_maturation"
      ],
      "properties": {
        "conceptual_trends": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1200
        },
        "methodological_trends": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1200
        },
        "theoretical_shifts": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1200
        },
        "evidence_maturation": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1200
        }
      }
    },
    "underexplored_periods": {
      "type": "array",
      "minItems": 0,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 4,
        "maxLength": 20
      }
    },
    "research_gaps": {
      "type": "array",
      "minItems": 0,
      "maxItems": 15,
      "items": {
        "type": "string",
        "minLength": 5,
        "maxLength": 250
      }
    },
    "future_directions": {
      "type": "array",
      "minItems": 0,
      "maxItems": 15,
      "items": {
        "type": "string",
        "minLength": 5,
        "maxLength": 250
      }
    },
    "epistemic_observations": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1600
    },
    "narrative_synthesis": {
      "type": "string",
      "minLength": 200,
      "maxLength": 9000
    }
  }
}
