{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "build_search_queries",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "domain",
    "core_concepts",
    "concept_expansion",
    "queries",
    "boolean_logic_guidance",
    "suggested_filters"
  ],
  "properties": {
    "domain": {
      "type": "string",
      "minLength": 2
    },
    "core_concepts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "concept_expansion": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "synonyms",
          "broader_terms",
          "narrower_terms",
          "related_terms"
        ],
        "properties": {
          "synonyms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "broader_terms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "narrower_terms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "related_terms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "queries": {
      "type": "array",
      "minItems": 8,
      "maxItems": 15,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "query",
          "lang",
          "type",
          "rationale"
        ],
        "properties": {
          "query": {
            "type": "string",
            "minLength": 2,
            "maxLength": 300
          },
          "lang": {
            "type": "string",
            "enum": [
              "fr",
              "en"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "core",
              "synonym",
              "broader",
              "narrower",
              "related"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 5,
            "maxLength": 500
          }
        }
      }
    },
    "boolean_logic_guidance": {
      "type": "string",
      "minLength": 5,
      "maxLength": 700
    },
    "suggested_filters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open_access_recommended",
        "date_range_recommendation",
        "discipline_filters"
      ],
      "properties": {
        "open_access_recommended": {
          "type": "boolean"
        },
        "date_range_recommendation": {
          "type": "string"
        },
        "discipline_filters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
